# ============================================================================
# Tsushin Backend — Local Development Environment
#
# For local dev (non-Docker). Docker deployments use the root .env file.
# Integration API keys are managed via UI/DB, not env vars.
# ============================================================================

# Application
TSN_APP_HOST=127.0.0.1
TSN_APP_PORT=8081

# Database
TSN_INTERNAL_DB_PATH=./data/agent.db

# Logging
TSN_LOG_FILE=logs/tsushin.log
TSN_LOG_LEVEL=INFO

# MCP Watcher
TSN_POLL_INTERVAL_MS=3000

# Authentication (REQUIRED)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Hub OAuth encryption
ASANA_ENCRYPTION_KEY=
ASANA_REDIRECT_URI=http://localhost:3030/hub/asana/callback

# External service URLs
# NOTE: KOKORO_SERVICE_URL was removed in v0.7.0. Kokoro TTS is now
# auto-provisioned per tenant via Hub → Kokoro TTS → Setup with Wizard.

# Container Runtime
TSN_CONTAINER_RUNTIME=docker
TSN_SECRET_BACKEND=env

# v0.7.0 Trigger Case Memory MVP (default OFF — experimental)
# When true, terminal trigger-driven runs (ContinuousRun and trigger-origin
# FlowRun) enqueue a `case_index` job that writes a compact CaseMemory row
# + up to 3 vectors (problem/action/outcome) to the tenant's resolved
# vector store. Skill `find_similar_past_cases` and the
# `/api/case-memory/*` admin endpoints become available. Leave OFF unless
# you have explicitly opted in for a tenant; the flag is global today.
TSN_CASE_MEMORY_ENABLED=false

# Postgres `idle_in_transaction_session_timeout` applied per-connection (ms).
# Default 15s is fine for short DB transactions. Raise to ≥60s if your stack
# drives long-running LLM calls (Vertex / Anthropic / etc.) inside transactions
# — Postgres will otherwise drop those connections mid-call with
# "server closed the connection unexpectedly" and the next request fails with
# "Session's transaction has been rolled back due to a previous exception".
TSN_DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=15000
